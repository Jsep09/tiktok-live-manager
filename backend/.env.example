# TikTok Live Viewer Manager — Backend Environment Variables

# Host TikTok username (optional, can be set via API)
# TIKTOK_HOST_USERNAME=@your_username

# Inactive threshold in minutes (default: 5)
INACTIVE_THRESHOLD_MINUTES=5

# WebSocket broadcast interval in seconds
WS_BROADCAST_INTERVAL=1

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
